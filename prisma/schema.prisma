generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  URGENT
  BLOCKED
  AWAITING_APPROVAL
  REJECTED
  COMPLETE
}

enum MemberRole {
  HEAD
  CO_HEAD
  MEMBER
}

enum NotificationType {
  ASSIGNED
  APPROVAL_REQUESTED
  APPROVED
  REJECTED
  DUE_SOON
  MENTIONED
  INVITED
}

enum CompletionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NodeType {
  TASK
  FOLDER
}

enum ProjectVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  imageUrl  String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Social links
  githubUrl   String?
  twitterUrl  String?
  linkedinUrl String?
  websiteUrl  String?

  // Preferences
  theme              String @default("system")
  emailNotifications Boolean @default(true)
  notifyAssigned     Boolean @default(true)
  notifyApproval     Boolean @default(true)
  notifyDueSoon      Boolean @default(true)
  notifyMentioned    Boolean @default(true)

  memberships       ProjectMember[]
  taskAssignments   TaskAssignment[]
  notifications     Notification[]
  messages          Message[]
  completionRequestsSubmitted CompletionRequest[] @relation("Requester")
  completionRequestsReceived  CompletionRequest[] @relation("Approver")
  comments          Comment[]
  directMessages    DirectMessage[]
  conversations     ConversationParticipant[]
  ownedTeams        Team[] @relation("TeamOwner")
  friends        Friendship[] @relation("UserFriends")
  friendOf       Friendship[] @relation("FriendOf")
  auditLogs      NodeAuditLog[]
  commentReads   CommentRead[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  shareToken  String?  @unique
  visibility  ProjectVisibility @default(PRIVATE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deleteAfter DateTime?

  members     ProjectMember[]
  graphs      Graph[]
  messages    Message[]
  labels      ProjectLabel[]
  permissions ProjectPermission[]
}

model ProjectMember {
  id        String     @id @default(cuid())
  userId    String
  projectId String
  role      MemberRole @default(MEMBER)
  createdAt DateTime   @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Graph {
  id        String   @id @default(cuid())
  projectId String
  name      String   @default("Root")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodes      TaskNode[]
  edges      Edge[]
  parentNode TaskNode?  @relation("SubGraph")
}

model TaskNode {
  id          String     @id @default(cuid())
  graphId     String
  title       String     @default("New Task")
  description String?
  status      TaskStatus @default(NOT_STARTED)
  nodeType    NodeType   @default(TASK)
  color       String?
  dueDate     DateTime?
  positionX   Float      @default(0)
  positionY   Float      @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  // Sub-graph relationship
  subGraphId String? @unique
  subGraph   Graph?  @relation("SubGraph", fields: [subGraphId], references: [id], onDelete: SetNull)

  graph       Graph            @relation(fields: [graphId], references: [id], onDelete: Cascade)
  assignments TaskAssignment[]
  attachments Attachment[]
  completionRequests CompletionRequest[]
  comments    Comment[]
  auditLogs   NodeAuditLog[]
  commentReads CommentRead[]

  // Edges
  outgoingEdges Edge[] @relation("SourceNode")
  incomingEdges Edge[] @relation("TargetNode")
}

model Edge {
  id           String @id @default(cuid())
  graphId      String
  sourceNodeId String
  targetNodeId String
  createdAt    DateTime @default(now())

  graph      Graph    @relation(fields: [graphId], references: [id], onDelete: Cascade)
  sourceNode TaskNode @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode TaskNode @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([sourceNodeId, targetNodeId])
}

model TaskAssignment {
  id        String  @id @default(cuid())
  nodeId    String
  userId    String
  isApprover Boolean @default(false)
  createdAt DateTime @default(now())

  node TaskNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([nodeId, userId])
}

model Attachment {
  id        String   @id @default(cuid())
  nodeId    String
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())

  node TaskNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

model CompletionRequest {
  id              String                  @id @default(cuid())
  nodeId          String
  requesterId     String
  approverId      String
  status          CompletionRequestStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  node      TaskNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  requester User     @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  approver  User     @relation("Approver", fields: [approverId], references: [id], onDelete: Cascade)
}

model Notification {
  id              String           @id @default(cuid())
  userId          String
  type            NotificationType
  message         String
  read            Boolean          @default(false)
  relatedNodeId   String?
  relatedProjectId String?
  createdAt       DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invite {
  id        String     @id @default(cuid())
  email     String
  projectId String
  role      MemberRole @default(MEMBER)
  token     String     @unique
  accepted  Boolean    @default(false)
  createdAt DateTime   @default(now())
  expiresAt DateTime
}

model Message {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  content   String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  nodeId    String
  userId    String
  content   String
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  node        TaskNode           @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments CommentAttachment[]
}

model CommentAttachment {
  id        String   @id @default(cuid())
  commentId String
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  isGroup   Boolean  @default(false)
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     DirectMessage[]
}

model ConversationParticipant {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model DirectMessage {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner   User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members TeamMember[]
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  email  String
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, email])
}

model ProjectLabel {
  id        String @id @default(cuid())
  projectId String
  name      String
  color     String @default("#7c3aed")
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  createdAt DateTime @default(now())

  user   User @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

model ProjectPermission {
  id                String     @id @default(cuid())
  projectId         String
  role              MemberRole
  canCreateNodes    Boolean    @default(true)
  canEditNodes      Boolean    @default(true)
  canDeleteNodes    Boolean    @default(true)
  canCreateEdges    Boolean    @default(true)
  canDeleteEdges    Boolean    @default(true)
  canChangeSettings Boolean    @default(false)
  canInviteMembers  Boolean    @default(false)
  canKickMembers    Boolean    @default(false)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, role])
}

model NodeAuditLog {
  id        String   @id @default(cuid())
  nodeId    String
  userId    String
  action    String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  node TaskNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CommentRead {
  id         String   @id @default(cuid())
  userId     String
  nodeId     String
  lastReadAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  node TaskNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([userId, nodeId])
}
